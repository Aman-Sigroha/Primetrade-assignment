# Copy to .env.local for local development
MONGODB_URI=mongodb://127.0.0.1:27017/primetrade
# Minimum 32 characters; use a long random value in production
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
# Browser API base (same origin can stay empty)
NEXT_PUBLIC_API_BASE=

# Optional SMTP config for OTP email delivery (if omitted, dev mode returns OTP in API response)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
